-- ТРИГГЕРНЫЕ ФУНКЦИИ
CREATE OR REPLACE FUNCTION zakazzs.log_status_change()
RETURNS TRIGGER AS $$
BEGIN
    -- Получаем имя пользователя из current_user или из контекста
    INSERT INTO zakazzs.istoriya_statusov (
        id_zayavki,
        stariy_status,
        noviy_status,
        data_izmeneniya,
        izmenil_kto,
        kommentariy
    ) VALUES (
        NEW.id_zayavki,
        OLD.id_status,
        NEW.id_status,
        NOW(),
        COALESCE(current_setting('app.current_user_name', true), 'Система'),
        'Изменение статуса'
    );
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION zakazzs.fn_update_timestamp()
RETURNS TRIGGER AS $$
BEGIN
    NEW.data_izmeneniya_zapisi = CURRENT_TIMESTAMP;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION zakazzs.fn_log_status_insert()
RETURNS TRIGGER AS $$
BEGIN
    -- Записываем создание новой заявки
    INSERT INTO zakazzs.istoriya_statusov (
        id_zayavki,
        stariy_status,
        noviy_status,
        data_izmeneniya,
        izmenil_kto,
        kommentariy
    ) VALUES (
        NEW.id_zayavki,
        NULL,
        NEW.id_status,
        CURRENT_TIMESTAMP,
        current_user,
        'Создана новая заявка'
    );
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION zakazzs.fn_log_status_change()
RETURNS TRIGGER AS $$
BEGIN
    -- Проверяем, изменился ли статус
    IF OLD.id_status IS DISTINCT FROM NEW.id_status THEN
        -- Записываем изменение в историю
        INSERT INTO zakazzs.istoriya_statusov (
            id_zayavki,
            stariy_status,
            noviy_status,
            data_izmeneniya,
            izmenil_kto,
            izmenil_id,
            izmenil_name,
            kommentariy
        ) VALUES (
            NEW.id_zayavki,
            OLD.id_status,
            NEW.id_status,
            CURRENT_TIMESTAMP,
            current_user,
            (SELECT id_sotrydnika FROM sortydnikis.sotrydniki WHERE s_nomer_telephona = current_user LIMIT 1),
            (SELECT s_familiya || ' ' || s_imya FROM sortydnikis.sotrydniki WHERE s_nomer_telephona = current_user LIMIT 1),
            CASE 
                WHEN NEW.id_status = 5 THEN 'Заявка выполнена и отправлена в архив'
                WHEN NEW.id_status = 6 THEN 'Заявка отменена'
                WHEN NEW.id_status = 1 AND OLD.id_status IS NULL THEN 'Создана новая заявка'
                ELSE 'Изменение статуса'
            END
        );
        
        -- Если новая заявка выполнена - автоматически архивируем
        IF NEW.id_status = 5 THEN
            NEW.is_archived := TRUE;
            NEW.archived_date := CURRENT_DATE;
        END IF;
        
        -- Если заявка отменена - тоже в архив
        IF NEW.id_status = 6 THEN
            NEW.is_archived := TRUE;
            NEW.archived_date := CURRENT_DATE;
        END IF;
        
        -- Если статус меняется с архива на активный
        IF OLD.id_status IN (5,6,7) AND NEW.id_status NOT IN (5,6,7) THEN
            NEW.is_archived := FALSE;
            NEW.archived_date := NULL;
        END IF;
    END IF;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION zakazzs.fn_auto_archive()
RETURNS TRIGGER AS $$
BEGIN
    -- При выполнении заявки (статус 5) - архивируем
    IF NEW.id_status = 5 AND OLD.id_status != 5 THEN
        NEW.is_archived := TRUE;
        NEW.archived_date := CURRENT_DATE;
    END IF;
    
    -- При отмене (статус 6) - архивируем
    IF NEW.id_status = 6 AND OLD.id_status != 6 THEN
        NEW.is_archived := TRUE;
        NEW.archived_date := CURRENT_DATE;
    END IF;
    
    -- Если возвращаем из архива в работу
    IF OLD.id_status IN (5,6,7) AND NEW.id_status NOT IN (5,6,7) THEN
        NEW.is_archived := FALSE;
        NEW.archived_date := NULL;
    END IF;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION zakazzs.fn_archive_completed_requests()
RETURNS TRIGGER AS $$
BEGIN
    IF NEW.id_status = 5 AND OLD.id_status != 5 THEN
        NEW.is_archived = TRUE;
        NEW.archived_date = CURRENT_DATE;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- ПРОЦЕДУРЫ
CREATE OR REPLACE PROCEDURE zakazzs.sp_change_zayavka_status(
    p_id_zayavki INTEGER,
    p_new_status_id INTEGER
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_current_status INTEGER;
    v_old_status_name TEXT;
    v_new_status_name TEXT;
BEGIN
    -- Получаем текущий статус
    SELECT id_status INTO v_current_status
    FROM zakazzs.zayavki
    WHERE id_zayavki = p_id_zayavki;
    
    IF v_current_status IS NULL THEN
        RAISE EXCEPTION 'Заявка с ID % не найдена', p_id_zayavki;
    END IF;
    
    -- Получаем названия статусов
    SELECT status_name INTO v_old_status_name FROM zakazzs.zayavki_status WHERE id_status = v_current_status;
    SELECT status_name INTO v_new_status_name FROM zakazzs.zayavki_status WHERE id_status = p_new_status_id;
    
    -- Обновляем статус (триггер сам запишет историю)
    UPDATE zakazzs.zayavki 
    SET id_status = p_new_status_id
    WHERE id_zayavki = p_id_zayavki;
    
    -- Выводим информацию
    RAISE NOTICE 'Статус заявки % изменен с "%" на "%"', 
        p_id_zayavki, v_old_status_name, v_new_status_name;
END;
$$;

CREATE OR REPLACE PROCEDURE zakazzs.sp_change_zayavka_status (
    p_id_zayavki INTEGER,
    p_new_status_id INTEGER,
    p_user_id INTEGER DEFAULT NULL
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_current_status INTEGER;
    v_old_status_name TEXT;
    v_new_status_name TEXT;
    v_user_name TEXT;
BEGIN
    -- Получаем текущий статус
    SELECT id_status INTO v_current_status
    FROM zakazzs.zayavki
    WHERE id_zayavki = p_id_zayavki;
    
    IF v_current_status IS NULL THEN
        RAISE EXCEPTION 'Заявка с ID % не найдена', p_id_zayavki;
    END IF;
    
    -- Получаем имена статусов
    SELECT status_name INTO v_old_status_name FROM zakazzs.zayavki_status WHERE id_status = v_current_status;
    SELECT status_name INTO v_new_status_name FROM zakazzs.zayavki_status WHERE id_status = p_new_status_id;
    
    -- Получаем имя пользователя, если передан ID
    IF p_user_id IS NOT NULL THEN
        SELECT s_familiya || ' ' || s_imya INTO v_user_name
        FROM sortydnikis.sotrydniki
        WHERE id_sotrydnika = p_user_id;
    ELSE
        v_user_name := current_user;
    END IF;
    
    -- Обновляем статус
    UPDATE zakazzs.zayavki 
    SET id_status = p_new_status_id
    WHERE id_zayavki = p_id_zayavki;
    
    -- Выводим информацию
    RAISE NOTICE 'Статус заявки % изменен с "%" на "%" пользователем %', 
        p_id_zayavki, v_old_status_name, v_new_status_name, COALESCE(v_user_name, current_user);
END;
$$;

CREATE OR REPLACE PROCEDURE zakazzs.sp_naznachit_ispolnitelya(
    p_id_zakaza INTEGER,
    p_id_voditelya INTEGER,
    p_id_mashini INTEGER
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_status_id BIGINT;
    v_voditel_fio TEXT;
    v_mashina_name TEXT;
    v_status_name TEXT := 'В работе';
BEGIN
    SELECT id_statusa_zakaza INTO v_status_id
    FROM zakazzs.statuszakaza
    WHERE status_zakaza = v_status_name;
    UPDATE zakazzs.zakaz
    SET 
        voditel = p_id_voditelya,
        mashina = p_id_mashini,
        status_zakaza = v_status_id
    WHERE id_zakaza = p_id_zakaza;
    IF NOT FOUND THEN
        RAISE EXCEPTION 'Заказ с ID % не найден!', p_id_zakaza;
    END IF;
    SELECT CONCAT(s.s_familiya, ' ', s.s_imya) INTO v_voditel_fio
    FROM sortydnikis.voditeli v
    JOIN sortydnikis.sotrydniki s ON v.id_sotrydnika = s.id_sotrydnika
    WHERE v.id_voditelya = p_id_voditelya;
    SELECT polnoe_nazvanie INTO v_mashina_name
    FROM mashini.mashinki
    WHERE id_mashini = p_id_mashini;
    RAISE NOTICE '--- Отчет о назначении ---';
    RAISE NOTICE 'Заказ №: %', p_id_zakaza;
    RAISE NOTICE 'Назначен водитель: %', v_voditel_fio;
    RAISE NOTICE 'Назначена машина: %', v_mashina_name;
    RAISE NOTICE 'Новый статус: %', v_status_name;
    RAISE NOTICE '--------------------------';
END;
$$;

-- ЕЩЕ ПРОЦЕДУРА
CREATE OR REPLACE PROCEDURE zakazzs.sp_obnovit_status_zakaza(
    p_id_zakaza INTEGER,
    p_noviy_status_text TEXT
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_status_id BIGINT;
BEGIN
    SELECT id_statusa_zakaza INTO v_status_id
    FROM zakazzs.statuszakaza
    WHERE status_zakaza = p_noviy_status_text;
    IF v_status_id IS NULL THEN
        RAISE EXCEPTION 'Статус "%" не найден в справочнике!', p_noviy_status_text;
    END IF;
    UPDATE zakazzs.zakaz
    SET status_zakaza = v_status_id
    WHERE id_zakaza = p_id_zakaza;
    IF NOT FOUND THEN
        RAISE EXCEPTION 'Заказ с ID % не найден!', p_id_zakaza;
    END IF;
    RAISE NOTICE 'Статус заказа % успешно изменен на "%"', p_id_zakaza, p_noviy_status_text;
END;
$$;

-- ЕЩЕ ПРОЦЕДУРА
CREATE OR REPLACE PROCEDURE zakazzs.sp_otmenit_zakaz (
p_id_zakaza INTEGER,
    p_prichina TEXT
)
LANGUAGE plpgsql
AS $$
DECLARE
    v_tekushiy_status TEXT;
    v_zakazchik_name TEXT;
    v_id_otmena INTEGER;
BEGIN
    SELECT sz.status_zakaza, zk.name_org INTO v_tekushiy_status, v_zakazchik_name
    FROM zakazzs.zakaz z
    JOIN zakazzs.statuszakaza sz ON z.status_zakaza = sz.id_statusa_zakaza
    JOIN zakazzs.zakazchiki zk ON z.zakazchik = zk.id_zakazchika
    WHERE z.id_zakaza = p_id_zakaza;
    IF v_tekushiy_status IS NULL THEN
        RAISE EXCEPTION 'Заказ №% не найден в базе данных!', p_id_zakaza;
    END IF;
    IF v_tekushiy_status = 'Завершен' THEN
        RAISE EXCEPTION 'Ошибка: Нельзя отменить заказ №%, так как он уже завершён.', p_id_zakaza;
    END IF;
    SELECT id_statusa_zakaza INTO v_id_otmena
    FROM zakazzs.statuszakaza
    WHERE status_zakaza = 'Отменен';
    UPDATE zakazzs.zakaz
    SET status_zakaza = v_id_otmena
    WHERE id_zakaza = p_id_zakaza;
    RAISE NOTICE '=== ОТМЕНА ЗАКАЗА УСПЕШНА ===';
    RAISE NOTICE 'Заказ №: %', p_id_zakaza;
    RAISE NOTICE 'Организация: %', v_zakazchik_name;
    RAISE NOTICE 'Причина отмены: %', p_prichina;
    RAISE NOTICE 'Прежний статус: %', v_tekushiy_status;
    RAISE NOTICE '=============================';
END;
$$;

-- ПРЕДСТАВЛЕНИЕ
CREATE OR REPLACE VIEW zakazzs.v_history_statusov AS
SELECT 
    i.id_loga AS "ID записи",
    i.id_zayavki AS "№ заявки",
    concat(z.adress_ot, ' - ', z.adress_do) AS "Маршрут",
    COALESCE(s1.status_name, 'Создана'::character varying) AS "Было",
    s2.status_name AS "Стало",
    i.data_izmeneniya AS "Дата изменения",
    COALESCE(i.izmenil_kto, 'Система'::character varying) AS "Кто изменил",
    COALESCE(i.kommentariy, ''::text) AS "Комментарий"
FROM 
    zakazzs.istoriya_statusov i
    JOIN zakazzs.zayavki z ON i.id_zayavki = z.id_zayavki
    LEFT JOIN zakazzs.zayavki_status s1 ON i.stariy_status = s1.id_status
    JOIN zakazzs.zayavki_status s2 ON i.noviy_status = s2.id_status;

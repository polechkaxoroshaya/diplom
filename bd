CREATE DATABASE www2

-- Схемы
CREATE SCHEMA IF NOT EXISTS mashini;
CREATE SCHEMA IF NOT EXISTS sortydnikis;
CREATE SCHEMA IF NOT EXISTS prog;
CREATE SCHEMA IF NOT EXISTS security;
CREATE SCHEMA IF NOT EXISTS zakazzs;

-- Таблица statysimashin
CREATE TABLE mashini.statysimashin (
    id_statysa_mashini SERIAL PRIMARY KEY,
    nazvanie_statysa VARCHAR(100) NOT NULL
);

-- Таблица obemikyzova
CREATE TABLE mashini.obemikyzova (
    id_obema SERIAL PRIMARY KEY,
    obem_v_paletax INTEGER NOT NULL,
    obem_ot INTEGER NOT NULL,
    obem_do INTEGER NOT NULL
);

-- Таблица gryzopodemnostimashin
CREATE TABLE mashini.gryzopodemnostimashin (
    id_gryz SERIAL PRIMARY KEY,
    tip VARCHAR(100) NOT NULL,
    gryz_ot INTEGER NOT NULL,
    gryz_do INTEGER NOT NULL
);

-- Таблица regioninomerovmashin
CREATE TABLE mashini.regioninomerovmashin (
    id_regiona SERIAL PRIMARY KEY,
    region_gorod VARCHAR(255) NOT NULL,
    region_chifra INTEGER NOT NULL
);

-- Таблица nomeramashin
CREATE TABLE mashini.nomeramashin (
    id_nomera SERIAL PRIMARY KEY,
    region BIGINT NOT NULL,
    nomer_mashini TEXT NOT NULL
);

ALTER TABLE mashini.nomeramashin
ADD CONSTRAINT fk_nomeramashin_regioninomerovmashin
FOREIGN KEY (region) REFERENCES mashini.regioninomerovmashin (id_regiona);

-- Таблица dolznosti
CREATE TABLE sortydnikis.dolznosti (
    id_dolznosti SERIAL PRIMARY KEY,
    nazvanie_dolznosti VARCHAR(100) NOT NULL
);

-- Таблица sotrydniki
CREATE TABLE sortydnikis.sotrydniki (
    id_sotrydnika SERIAL PRIMARY KEY,
    s_imya VARCHAR(100) NOT NULL,
    s_familiya VARCHAR(100) NOT NULL,
    s_otchestvo VARCHAR(100),
    s_nomer_telephona VARCHAR(20) NOT NULL,
    dolzhnost INTEGER NOT NULL,
    s_data_rozdeniya DATE NOT NULL,
    data_priema DATE NOT NULL
);

-- Таблица voditeli
CREATE TABLE sortydnikis.voditeli (
    id_voditelya SERIAL PRIMARY KEY,
    id_sotrydnika INTEGER NOT NULL,
    passport_data VARCHAR(100) NOT NULL,
    driver_license_number VARCHAR(50) NOT NULL
);

ALTER TABLE sortydnikis.voditeli
ADD CONSTRAINT fk_voditeli_sotrydniki
FOREIGN KEY (id_sotrydnika) REFERENCES sortydnikis.sotrydniki(id_sotrydnika);

-- Таблица users
CREATE TABLE security.users (
    id_user SERIAL PRIMARY KEY,
    login VARCHAR(50) NOT NULL,
    password_hash VARCHAR(64) NOT NULL,
    password_salt VARCHAR(32) NOT NULL,
    id_sotrydnika BIGINT NOT NULL
);

ALTER TABLE security.users
ADD CONSTRAINT fk_users_sotrydniki
FOREIGN KEY (id_sotrydnika) REFERENCES sortydnikis.sotrydniki(id_sotrydnika);

-- Таблица polzovateli
CREATE TABLE prog.polzovateli (
    id_polzovatelya SERIAL PRIMARY KEY,
    p_name VARCHAR(100) NOT NULL,
    p_familyia VARCHAR(100) NOT NULL,
    p_otchestvo VARCHAR(100),
    phone VARCHAR(20) NOT NULL,
    email VARCHAR(100)
);

-- Таблица users_polz
CREATE TABLE prog.users_polz (
    id_user_p SERIAL PRIMARY KEY,
    login_p VARCHAR(50) NOT NULL,
    password_hash_user VARCHAR(64) NOT NULL,
    password_salt_user VARCHAR(32) NOT NULL,
    id_polzovatelya INTEGER NOT NULL
);

ALTER TABLE prog.users_polz
ADD CONSTRAINT fk_userspolz_polzovateli
FOREIGN KEY (id_user_p) REFERENCES prog.polzovateli(id_polzovatelya);


-- Таблица zayavki_status
CREATE TABLE zakazzs.zayavki_status (
    id_status SERIAL PRIMARY KEY,
    status_name VARCHAR(50) NOT NULL,
    status_order INTEGER NOT NULL,
    is_active BOOLEAN DEFAULT TRUE,
    color_code VARCHAR(7) DEFAULT '#000000'
);

-- Таблица companies
CREATE TABLE prog.companies (
    id_company SERIAL PRIMARY KEY,
    name VARCHAR(200) NOT NULL,
    inn VARCHAR(12),
    kpp VARCHAR(9),
    ogrn VARCHAR(13),
    legal_address VARCHAR(500),
    actual_address VARCHAR(500),
    phone VARCHAR(50),
    email VARCHAR(100),
    director_name VARCHAR(200),
    bank_name VARCHAR(200),
    bik VARCHAR(9),
    correspondent_account VARCHAR(20),
    checking_account VARCHAR(20),
    created_at TIMESTAMP WITHOUT TIME ZONE,
    is_active BOOLEAN
);

-- Таблица mashinki
CREATE TABLE mashini.mashinki (
    id_mashini SERIAL PRIMARY KEY,
    marka VARCHAR(100) NOT NULL,
    polnoe_nazvanie VARCHAR(100) NOT NULL,
    nomer INTEGER NOT NULL,
    gryzopodemnost INTEGER NOT NULL,
    obem_kyzova INTEGER NOT NULL,
    statys_mashini INTEGER NOT NULL
);

ALTER TABLE mashini.mashinki
ADD CONSTRAINT fk_mashinki_nomeramashin
FOREIGN KEY (nomer) REFERENCES mashini.nomeramashin(id_nomera);

ALTER TABLE mashini.mashinki
ADD CONSTRAINT fk_mashinki_gryzopodemnostimashin
FOREIGN KEY (gryzopodemnost) REFERENCES mashini.gryzopodemnostimashin(id_gryz);

ALTER TABLE mashini.mashinki
ADD CONSTRAINT fk_mashinki_obemikyzova
FOREIGN KEY (obem_kyzova) REFERENCES mashini.obemikyzova(id_obema);

ALTER TABLE mashini.mashinki
ADD CONSTRAINT fk_mashinki_statysimashin
FOREIGN KEY (statys_mashini) REFERENCES mashini.statysimashin(id_statysa_mashini);

-- Таблица user_companies
CREATE TABLE prog.user_companies (
    id_user_company SERIAL PRIMARY KEY,
    id_polzovatelya INTEGER NOT NULL,
    id_company INTEGER NOT NULL,
    is_default BOOLEAN,
    position_in_company VARCHAR(100),
    created_at TIMESTAMP WITHOUT TIME ZONE
);

ALTER TABLE prog.user_companies
ADD CONSTRAINT fk_usercompanies_polzovateli
FOREIGN KEY (id_polzovatelya) REFERENCES prog.polzovateli(id_polzovatelya);

ALTER TABLE prog.user_companies
ADD CONSTRAINT fk_usercompanies_companies
FOREIGN KEY (id_company) REFERENCES prog.companies (id_company);

-- Таблица zayavki
CREATE TABLE zakazzs.zayavki (
    id_zayavki SERIAL PRIMARY KEY,
    data_podachi DATE DEFAULT CURRENT_DATE,
    data_podachi_mashiny DATE,
    vremya_dostavki TIME WITHOUT TIME ZONE,
    adress_ot VARCHAR(500) NOT NULL,
    adress_do VARCHAR(500) NOT NULL,
    lontaktnoe_lico_otpravitel VARCHAR(200),
    telefon_otpravitel VARCHAR(50),
    naimenovanie_gruza VARCHAR(500),
    obschiy_ves_kg NUMERIC(10, 2),
    obschiy_obem_m3 NUMERIC(10, 2),
    kolvo_mest VARCHAR(100),
    dilna_m NUMERIC(8, 2),
    shirina_m NUMERIC(8, 2),
    vysota_m NUMERIC(8, 2),
    list_otpravitelya BOOLEAN DEFAULT FALSE,
    list_eksporta BOOLEAN DEFAULT FALSE,
    stoimost_grupa_dlya_straho NUMERIC(12, 2),
    tip_transporta VARCHAR(50),
    zagruzka_zadnyaya BOOLEAN DEFAULT FALSE,
    zagruzka_bokovaya BOOLEAN DEFAULT FALSE,
    zagruzka_verhnyaya BOOLEAN DEFAULT FALSE,
    propusk_mozhd BOOLEAN DEFAULT FALSE,
    propusk_ttk BOOLEAN DEFAULT FALSE,
    propusksadovoekoltso BOOLEAN DEFAULT FALSE,
    poluchatel_organizatsiya VARCHAR(300),
    poluchatel_adress VARCHAR(500),
    poluchatel_kontakt VARCHAR(200),
    poluchatel_telefon VARCHAR(50),
    platetschik VARCHAR(300),
    prochee TEXT,
    id_zakazchika INTEGER NOT NULL,
    created_at TIMESTAMP WITHOUT TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    id_zakaza INTEGER,
    id_company INTEGER,
    id_status INTEGER DEFAULT 1,
    is_archived BOOLEAN DEFAULT FALSE,
    archived_date DATE,
    id_voditel INTEGER,
    id_mashina INTEGER
);

ALTER TABLE zakazzs.zayavki
ADD CONSTRAINT fk_zayavki_companies
FOREIGN KEY (id_company) REFERENCES prog.companies(id_company);

ALTER TABLE zakazzs.zayavki
ADD CONSTRAINT fk_zayavki_voditeli
FOREIGN KEY (id_voditel) REFERENCES sortydnikis.voditeli(id_voditelya);

ALTER TABLE zakazzs.zayavki
ADD CONSTRAINT fk_zayavki_zayavkistatus
FOREIGN KEY (id_status) REFERENCES zakazzs.zayavki_status(id_status);

ALTER TABLE zakazzs.zayavki
ADD CONSTRAINT fk_zayavki_polzovateli
FOREIGN KEY (id_zakazchika) REFERENCES prog.polzovateli(id_polzovatelya);

ALTER TABLE zakazzs.zayavki
ADD CONSTRAINT fk_zayavki_mashinki
FOREIGN KEY (id_mashina) REFERENCES mashini.mashinki(id_mashini);

-- Таблица istoriya_statusov
CREATE TABLE zakazzs.istoriya_statusov (
    id_loga SERIAL PRIMARY KEY,
    id_zayavki BIGINT NOT NULL,
    stariy_status BIGINT,
    noviy_status BIGINT NOT NULL,
    data_izmeneniya TIMESTAMP WITHOUT TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    izmenil_kto VARCHAR(100),
    kommentariy TEXT,
    izmenil_id BIGINT,
    izmenil_name VARCHAR(100) DEFAULT 'Система'
);

ALTER TABLE zakazzs.istoriya_statusov
ADD CONSTRAINT fk_istoriyastatusov_zayavki
FOREIGN KEY (id_zayavki) REFERENCES zakazzs.zayavki(id_zayavki);

